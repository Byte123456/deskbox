{
  "productName": "DeskBox",
  "version": "0.1.0",
  "identifier": "com.deskbox.app",
  "build": {
    "frontendDist": "../frontend-dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DeskBox",
        "width": 680,
        "height": 520,
        "center": true,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "DeskBox - 桌面收纳"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/16x16.png",
      "icons/32x32.png",
      "icons/48x48.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "languages": ["English", "SimpChinese"],
        "displayLanguageSelector": true,
        "startMenuFolder": "DeskBox"
      }
    }
  },
  "plugins": {}
}
